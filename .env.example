# ── ScaleUp environment ───────────────────────────────────────────────────────
# Copy to .env for local development. In production set these in
# Vercel → Project → Settings → Environment Variables.

# Supabase (user accounts + personal library). The URL and anon key are PUBLIC
# by design — Row Level Security protects the data. Get both from
# Supabase → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic — SERVER-ONLY key used by the /api/anthropic proxy in production.
# Never prefix this one with VITE_.
ANTHROPIC_API_KEY=

# Optional, LOCAL DEV ONLY: lets the browser call Anthropic directly without
# the proxy (vite dev has no /api). Anyone can read a VITE_ var from the
# bundle — never set this in production.
# VITE_ANTHROPIC_API_KEY=
